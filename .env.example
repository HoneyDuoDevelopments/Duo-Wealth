# Duo Wealth — Environment Configuration
# Copy to .env and fill in values from Vaultwarden → Infrastructure → "Duo Wealth DB"
#
# NEVER commit the actual .env file

# PostgreSQL — Test Instance
POSTGRES_TEST_USER=duo_wealth_test
POSTGRES_TEST_PASSWORD=CHANGE_ME
POSTGRES_TEST_DB=duo_wealth_test
POSTGRES_TEST_PORT=5433

# PostgreSQL — Production Instance
POSTGRES_PROD_USER=duo_wealth
POSTGRES_PROD_PASSWORD=CHANGE_ME
POSTGRES_PROD_DB=duo_wealth
POSTGRES_PROD_PORT=5434
